SGIE_RECORDATORIOS_ANTICIPO_REPETIR_CADA_HORAS=24
SGIE_RECORDATORIOS_ANTICIPO_PROGRAMADOS_SCHEDULER_ENABLED=true
SGIE_RECORDATORIOS_ANTICIPO_PROGRAMADOS_SCHEDULER_CRON=0 0 9 * * *
