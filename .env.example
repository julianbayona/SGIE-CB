DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgie
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Railway PostgreSQL expone normalmente estas variables.
# Si existen, tienen prioridad sobre DB_HOST/DB_PORT/DB_NAME/DB_USERNAME/DB_PASSWORD.
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

PORT=8080
FLYWAY_ENABLED=true
HIBERNATE_DDL_AUTO=update

SGIE_AUTH_JWT_SECRET=change-this-secret-before-deploying-sgie-club-boyaca
SGIE_AUTH_JWT_EXPIRATION_MINUTES=30
SGIE_CORS_ALLOWED_ORIGINS=http://localhost:5173

SGIE_NOTIFICACIONES_SCHEDULER_FIXED_DELAY_MS=60000
